{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "stage traffic lane changes",
			"type": "shell",
			"command": "git",
			"args": [
				"add",
				"-A"
			],
			"isBackground": false
		},
		{
			"label": "profile planner hotspots",
			"type": "shell",
			"command": "node",
			"args": [
				"profile_planner_hotspots.js",
				"--lanes",
				"3",
				"--cars",
				"40",
				"--split",
				"50",
				"--seed",
				"307",
				"--ticks",
				"400",
				"--dt",
				"1"
			],
			"isBackground": false
		},
		{
			"label": "run traffic guards",
			"type": "shell",
			"command": "node",
			"args": [
				"run_traffic_suite.js",
				"--id",
				"P",
				"--id",
				"S",
				"--id",
				"AA",
				"--id",
				"X",
				"--strict"
			],
			"isBackground": false
		},
		{
			"label": "commit-traffic-clean",
			"type": "shell",
			"command": "git",
			"args": [
				"add",
				"traffic_core.js",
				"&&",
				"git",
				"commit",
				"-m",
				"fix: reduce planner legality overhead",
				"-m",
				"- add a distance-based early reject before SAT overlap checks",
				"-m",
				"- skip corner clearance work when the vehicle center is already safely inside the road"
			],
			"isBackground": false,
			"group": "build"
		},
		{
			"label": "repo-push-helper",
			"type": "shell",
			"command": "C:/Users/otavi/Documents/prova-ai/.venv/Scripts/python.exe",
			"args": [
				"repo_push_helper.py"
			],
			"isBackground": false,
			"group": "build"
		},
		{
			"label": "repo-push-helper",
			"type": "shell",
			"command": "C:/Users/otavi/Documents/prova-ai/.venv/Scripts/python.exe",
			"args": [
				"repo_push_helper.py"
			],
			"isBackground": false,
			"group": "build"
		}
	]
}